# .vscodeignore

# Exclude test files and directories
**/test/**
**/tests/**
**/*.test.js
**/*.test.ts
**/*.spec.js
**/*.spec.ts
**/*.test.js.map
**/*.test.ts.map

# Exclude development files
.vscode/**
.vscode-test/**
src/**
scripts/**
**/*.map
**/*.ts
**/*.tsx

# Exclude dev dependencies but include production dependencies
node_modules/**
!node_modules/strip-ansi/**
!node_modules/strip-ansi/**/*
!node_modules/ansi-regex/**
!node_modules/ansi-regex/**/*

# Build and dev tools
webpack.config.js
tsconfig.json
tsconfig.test.json
.eslintrc.json
.prettierrc
.actrc
Dockerfile

# Documentation and examples
docs/**
examples/**
*.md
!README.md
CONTRIBUTING.md

# CI/CD
.github/**
.gitignore
.gitattributes

# Logs and temp
logs/**
*.log
*.tmp
*.temp
coverage/**
.nyc_output/**
.vscode-test/**