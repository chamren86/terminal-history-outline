# Exclude source files
src/
test/

# Exclude compiled test files
out/test/
out/test/**
out/**/test/
out/**/test/**
**/*.test.js
**/*.test.ts
**/*.spec.js
**/*.spec.ts

# Exclude all map files
*.map
**/*.map

# Exclude development files
.git/
.vscode/
node_modules/
package-lock.json
tsconfig.json
tsconfig.test.json
vitest.config.ts
eslint.config.mjs
.vscode-test.mjs
.nvmrc
.gitignore
.vscodeignore

# Exclude documentation and scripts
ROADMAP/
docs/
scripts/
.github/

# Keep only what's necessary for the extension
!package.json
!README.md
!LICENSE.md
!out/**/*.js
!out/constants/**
!out/enums/**
!out/interfaces/**