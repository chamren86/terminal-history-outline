# .vscodeignore

# Exclude all test files and directories
**/test/**
**/tests/**
**/*.test.js
**/*.test.ts
**/*.spec.js
**/*.spec.ts
**/*.test.js.map
**/*.test.ts.map

# Exclude test output
out/test/**
out/**/*.test.js

# Development files
.vscode/**
.vscode-test/**
src/**
scripts/**
**/*.map
**/*.ts
**/*.tsx

# Node modules (except vscode)
node_modules/**
!node_modules/vscode/**

# Build and dev tools
webpack.config.js
tsconfig.json
tsconfig.test.json
.eslintrc.json
.prettierrc
.actrc
Dockerfile

# Documentation and examples
docs/**
examples/**
*.md
!README.md
CONTRIBUTING.md

# CI/CD
.github/**
.gitignore
.gitattributes

# Logs and temp
logs/**
*.log
*.tmp
*.temp
coverage/**
.nyc_output/**
.vscode-test/**

# OS files
.DS_Store
Thumbs.db